[TEMPLATE]
# Nyaya AI - Backend Environment Variables
# Copy this file to .env and fill in your values

# REQUIRED: Groq API key for AI features (free, no credit card from https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL: Google Gemini API key (fallback, free from https://aistudio.google.com/)
# GEMINI_API_KEY=your_gemini_api_key_here

# REQUIRED: Indian Kanoon API token (free from https://indiankanoon.org/api/)
KANOON_API_TOKEN=your_kanoon_api_token_here

# OPTIONAL: Firebase service account credentials (JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# OPTIONAL: Path to Firebase credentials JSON file (relative to backend/)
FIREBASE_CREDENTIALS_PATH=nyaya-app-9712a-firebase-adminsdk-fbsvc-790c273478.json

# OPTIONAL: Daily AI requests limit per user (default: 50)
DAILY_AI_REQUESTS_PER_USER=50

# OPTIONAL: Allowed CORS origins, comma-separated
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
